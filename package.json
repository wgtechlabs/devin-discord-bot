{
	"name": "devin-discord-bot",
	"version": "0.1.5",
	"description": "Self-hosted Discord bot integration for Devin AI",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target node",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"prepare": "biome check ."
	},
	"keywords": [
		"discord",
		"bot",
		"devin",
		"ai",
		"typescript",
		"discord.js",
		"self-hosted",
		"automation"
	],
	"author": "WG Tech Labs",
	"license": "GPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/wgtechlabs/devin-discord-bot.git"
	},
	"homepage": "https://github.com/wgtechlabs/devin-discord-bot",
	"bugs": {
		"url": "https://github.com/wgtechlabs/devin-discord-bot/issues"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"discord.js": "^14.18.0",
		"pg": "^8.22.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "^1.2.14",
		"@types/pg": "^8.20.0",
		"typescript": "^5.8.3"
	}
}
