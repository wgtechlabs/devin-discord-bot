# Discord Bot Configuration
# Get these from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# Devin API Configuration
# Get your API key from https://app.devin.ai
# For legacy v1 keys (apk_* / apk_user_*), only DEVIN_API_KEY is required.
# For service-user v3 keys (cog_*), DEVIN_ORG_ID is also required.
DEVIN_API_KEY=apk_your_devin_api_key_here
# DEVIN_ORG_ID=org_your_devin_org_id_here

# Bot Name (optional — customizes embed headers and thread names)
# BOT_NAME=Devin

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
